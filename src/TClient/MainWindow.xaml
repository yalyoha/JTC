<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="TClient.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:TClient.ViewModels"
    Title="TClient">
    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="32" Background="Transparent">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="12,0,0,0"
                        Spacing="8">
                <TextBlock Text="TClient"
                           VerticalAlignment="Center"
                           Style="{ThemeResource CaptionTextBlockStyle}" />
                <TextBlock x:Name="VersionText"
                           VerticalAlignment="Center"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                <Button x:Name="OpenTorrentButton" Click="OpenTorrentButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE710;" />
                        <TextBlock Text="Открыть .torrent" />
                    </StackPanel>
                </Button>
                <Button x:Name="AddMagnetButton" Click="AddMagnetButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE71B;" />
                        <TextBlock Text="Добавить magnet" />
                    </StackPanel>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                <Button x:Name="ResumeButton" Click="ResumeButton_Click"
                        ToolTipService.ToolTip="Возобновить">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE768;" />
                </Button>
                <Button x:Name="PauseButton" Click="PauseButton_Click"
                        ToolTipService.ToolTip="Пауза">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE769;" />
                </Button>
                <Button x:Name="RemoveButton" Click="RemoveButton_Click"
                        ToolTipService.ToolTip="Удалить">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE74D;" />
                </Button>
                <Button x:Name="SettingsButton" Click="SettingsButton_Click"
                        ToolTipService.ToolTip="Настройки"
                        Margin="12,0,0,0">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE713;" />
                </Button>
            </StackPanel>
        </Grid>

        <ListView Grid.Row="2"
                  x:Name="TorrentList"
                  ItemsSource="{x:Bind ViewModel.Torrents, Mode=OneWay}"
                  SelectedItem="{x:Bind ViewModel.SelectedTorrent, Mode=TwoWay}"
                  SelectionMode="Single"
                  Padding="12,0,12,0">
            <ListView.HeaderTemplate>
                <DataTemplate>
                    <Grid Padding="8,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.5*" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="1.6*" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Имя"       Style="{ThemeResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Column="1" Text="Размер"    Style="{ThemeResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Column="2" Text="Прогресс"  Style="{ThemeResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Column="3" Text="↓"         Style="{ThemeResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Column="4" Text="↑"         Style="{ThemeResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Column="5" Text="Пиры"      Style="{ThemeResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Column="6" Text="Состояние" Style="{ThemeResource CaptionTextBlockStyle}" />
                    </Grid>
                </DataTemplate>
            </ListView.HeaderTemplate>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:TorrentViewModel">
                    <Grid Padding="4,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.5*" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="1.6*" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                   Text="{x:Bind Name, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                   Text="{x:Bind SizeText, Mode=OneWay}" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                   Text="{x:Bind ProgressText, Mode=OneWay}" />
                        <TextBlock Grid.Column="3" VerticalAlignment="Center"
                                   Text="{x:Bind DownloadRateText, Mode=OneWay}" />
                        <TextBlock Grid.Column="4" VerticalAlignment="Center"
                                   Text="{x:Bind UploadRateText, Mode=OneWay}" />
                        <TextBlock Grid.Column="5" VerticalAlignment="Center"
                                   Text="{x:Bind PeerCount, Mode=OneWay}" />
                        <TextBlock Grid.Column="6" VerticalAlignment="Center"
                                   Text="{x:Bind StateText, Mode=OneWay}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid Grid.Row="3" Padding="12,6" Background="{ThemeResource LayerFillColorDefaultBrush}">
            <StackPanel Orientation="Horizontal" Spacing="18">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE74B;" />
                    <TextBlock Text="{x:Bind ViewModel.TotalDownloadRateText, Mode=OneWay}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE74A;" />
                    <TextBlock Text="{x:Bind ViewModel.TotalUploadRateText, Mode=OneWay}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Пиры:" />
                    <TextBlock Text="{x:Bind ViewModel.TotalPeers, Mode=OneWay}" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
