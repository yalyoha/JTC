<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="TClient.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:TClient.ViewModels"
    Title="TClient">
    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="32" Background="Transparent">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="12,0,0,0"
                        Spacing="8">
                <TextBlock Text="TClient"
                           VerticalAlignment="Center"
                           Style="{ThemeResource CaptionTextBlockStyle}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                <Button x:Name="OpenTorrentButton" Click="OpenTorrentButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE710;" />
                        <TextBlock Text="Open .torrent" />
                    </StackPanel>
                </Button>
                <Button x:Name="AddMagnetButton" Click="AddMagnetButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE71B;" />
                        <TextBlock Text="Add magnet" />
                    </StackPanel>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                <Button x:Name="ResumeButton" Click="ResumeButton_Click"
                        ToolTipService.ToolTip="Resume">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE768;" />
                </Button>
                <Button x:Name="PauseButton" Click="PauseButton_Click"
                        ToolTipService.ToolTip="Pause">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE769;" />
                </Button>
                <Button x:Name="RemoveButton" Click="RemoveButton_Click"
                        ToolTipService.ToolTip="Remove">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE74D;" />
                </Button>
            </StackPanel>
        </Grid>

        <ListView Grid.Row="2"
                  x:Name="TorrentList"
                  ItemsSource="{x:Bind ViewModel.Torrents, Mode=OneWay}"
                  SelectedItem="{x:Bind ViewModel.SelectedTorrent, Mode=TwoWay}"
                  SelectionMode="Single"
                  Padding="12,0,12,0">
            <ListView.HeaderTemplate>
                <DataTemplate>
                    <Grid Padding="8,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.5*" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="1.6*" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Name"     Style="{ThemeResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Column="1" Text="Size"     Style="{ThemeResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Column="2" Text="Progress" Style="{ThemeResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Column="3" Text="Down"     Style="{ThemeResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Column="4" Text="Up"       Style="{ThemeResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Column="5" Text="Peers"    Style="{ThemeResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Column="6" Text="State"    Style="{ThemeResource CaptionTextBlockStyle}" />
                    </Grid>
                </DataTemplate>
            </ListView.HeaderTemplate>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:TorrentViewModel">
                    <Grid Padding="4,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.5*" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="1.6*" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Bind Name, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1" Text="{x:Bind SizeText, Mode=OneWay}" />
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <ProgressBar Value="{x:Bind Progress, Mode=OneWay}"
                                         Maximum="100"
                                         Width="140" />
                            <TextBlock Text="{x:Bind ProgressText, Mode=OneWay}" />
                        </StackPanel>
                        <TextBlock Grid.Column="3" Text="{x:Bind DownloadRateText, Mode=OneWay}" />
                        <TextBlock Grid.Column="4" Text="{x:Bind UploadRateText, Mode=OneWay}" />
                        <TextBlock Grid.Column="5" Text="{x:Bind PeerCount, Mode=OneWay}" />
                        <TextBlock Grid.Column="6" Text="{x:Bind StateText, Mode=OneWay}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>
