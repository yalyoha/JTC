<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="TClient.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="TClient">
    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="32" Background="Transparent">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="12,0,0,0"
                        Spacing="8">
                <TextBlock Text="TClient"
                           VerticalAlignment="Center"
                           Style="{ThemeResource CaptionTextBlockStyle}" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Padding="12,8"
                    Spacing="8">
            <Button x:Name="OpenTorrentButton"
                    Click="OpenTorrentButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE710;" />
                    <TextBlock Text="Open .torrent" />
                </StackPanel>
            </Button>
            <Button x:Name="AddMagnetButton"
                    Click="AddMagnetButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE71B;" />
                    <TextBlock Text="Add magnet" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>
