<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="JTC.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:JTC.ViewModels"
    xmlns:tb="using:H.NotifyIcon"
    Title="Junior Torrent Client">
    <Grid x:Name="RootGrid">
        <!-- Background + RequestedTheme are set from code-behind via ThemeHelper based on
             the user's chosen theme (Brand / Dark / Light). -->
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Tray icon — the app minimizes here on window-close instead of quitting,
             so the torrent engine keeps seeding/leeching in the background. -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        IconSource="Assets/tclient.ico"
                        ToolTipText="Junior Torrent Client"
                        NoLeftClickDelay="True"
                        MenuActivation="RightClick">
            <tb:TaskbarIcon.ContextFlyout>
                <!-- Click= handlers on these items are wired in code-behind (MainWindow ctor).
                     XAML Click= assignment on MenuFlyoutItems inside TaskbarIcon.ContextFlyout
                     doesn't reliably reach the compiled code-behind — the flyout is realized
                     on the shell/notification-area surface, outside the WinUI element tree. -->
                <MenuFlyout>
                    <MenuFlyoutItem x:Name="TrayShowItem" Text="Показать" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem x:Name="TrayExitItem" Text="Выход" />
                </MenuFlyout>
            </tb:TaskbarIcon.ContextFlyout>
        </tb:TaskbarIcon>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="32" Background="Transparent">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="12,0,0,0"
                        Spacing="8">
                <TextBlock Text="Junior Torrent Client"
                           VerticalAlignment="Center"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                <TextBlock x:Name="VersionText"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                <Button x:Name="OpenTorrentButton" Click="OpenTorrentButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE710;" />
                        <TextBlock Text="Открыть .torrent" />
                    </StackPanel>
                </Button>
                <Button x:Name="AddMagnetButton" Click="AddMagnetButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE71B;" />
                        <TextBlock Text="Добавить magnet" />
                    </StackPanel>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                <Button x:Name="ResumeButton" Click="ResumeButton_Click"
                        ToolTipService.ToolTip="Возобновить">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE768;" />
                </Button>
                <Button x:Name="PauseButton" Click="PauseButton_Click"
                        ToolTipService.ToolTip="Пауза">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE769;" />
                </Button>
                <Button x:Name="RemoveButton" Click="RemoveButton_Click"
                        ToolTipService.ToolTip="Удалить">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE74D;" />
                </Button>
                <Button x:Name="SettingsButton" Click="SettingsButton_Click"
                        ToolTipService.ToolTip="Настройки"
                        Margin="12,0,0,0">
                    <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE713;" />
                </Button>
            </StackPanel>
        </Grid>

        <ListView Grid.Row="2"
                  x:Name="TorrentList"
                  ItemsSource="{x:Bind ViewModel.Torrents, Mode=OneWay}"
                  SelectedItem="{x:Bind ViewModel.SelectedTorrent, Mode=TwoWay}"
                  SelectionMode="Extended"
                  SelectionChanged="TorrentList_SelectionChanged"
                  Tapped="TorrentList_Tapped"
                  Padding="12,0,12,0">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <!-- Default ListViewItem constrains its content to Left + adds padding.
                         Stretch so our row Grid gets the full width, and zero padding so
                         our own Grid Padding is the only spacer. -->
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,3" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.Resources>
                <!-- Kill the built-in hover/selection overlays. Our per-state row-background
                     is the only visual state indicator; without these overrides, the WinUI
                     hover overlay renders slightly wider than our row Grid and looks weird. -->
                <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver"          Color="Transparent" />
                <SolidColorBrush x:Key="ListViewItemBackgroundPressed"              Color="Transparent" />
                <!-- Container selection background is off; selection is rendered inside
                     our row Grid via TorrentViewModel.IsSelected so the shape matches. -->
                <SolidColorBrush x:Key="ListViewItemBackgroundSelected"             Color="Transparent" />
                <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver"  Color="Transparent" />
                <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed"      Color="Transparent" />
            </ListView.Resources>
            <ListView.HeaderTemplate>
                <DataTemplate>
                    <Grid Padding="8,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.5*" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="1.6*" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <!-- Имя — left-aligned (long text with ellipsis). Размер / Прогресс /
                             Пиры / Состояние — centred so short values (numbers, percentages,
                             short state labels) sit tidily in their column instead of hugging
                             the left edge. Rate columns (↓ / ↑) stay left because their unit
                             changes width (B/s → KB/s → MB/s) and centring would jitter. -->
                        <TextBlock Grid.Column="0" Text="Имя"       Style="{ThemeResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Column="1" Text="Размер"    Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="Прогресс"  Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="3" Text="↓"         Style="{ThemeResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Column="4" Text="↑"         Style="{ThemeResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Column="5" Text="Пиры"      Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="6" Text="Состояние" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </ListView.HeaderTemplate>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:TorrentViewModel">
                    <!-- Border wraps the row so its CornerRadius clips both the plashka background
                         (RowBackground gradient) AND the 4px status stripe on the left edge; a
                         plain Grid.CornerRadius would only clip its own background, not children. -->
                    <Border CornerRadius="4"
                            Background="{x:Bind RowBackground, Mode=OneWay}"
                            DoubleTapped="TorrentRow_DoubleTapped">
                        <Border.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Открыть" Click="RowOpen_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE838;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Обновить" Click="RowRecheck_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE72C;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Удалить" Click="RowDelete_Click">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE74D;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Border.ContextFlyout>
                        <Grid>
                            <!-- 4px status stripe on the left edge; visible only outside the
                                 rounded corners because the parent Border clips it. -->
                            <Rectangle HorizontalAlignment="Left"
                                       VerticalAlignment="Stretch"
                                       Width="4"
                                       Fill="{x:Bind StatusBrush, Mode=OneWay}" />
                            <Grid Padding="12,10,12,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2.5*" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="1.6*" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                           Foreground="{x:Bind RowForeground, Mode=OneWay}"
                                           Text="{x:Bind Name, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                                           Foreground="{x:Bind RowForeground, Mode=OneWay}"
                                           Text="{x:Bind SizeText, Mode=OneWay}" />
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                                           Foreground="{x:Bind RowForeground, Mode=OneWay}"
                                           Text="{x:Bind ProgressText, Mode=OneWay}" />
                                <TextBlock Grid.Column="3" VerticalAlignment="Center"
                                           Foreground="{x:Bind RowForeground, Mode=OneWay}"
                                           Text="{x:Bind DownloadRateText, Mode=OneWay}" />
                                <TextBlock Grid.Column="4" VerticalAlignment="Center"
                                           Foreground="{x:Bind RowForeground, Mode=OneWay}"
                                           Text="{x:Bind UploadRateText, Mode=OneWay}" />
                                <TextBlock Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Center"
                                           Foreground="{x:Bind RowForeground, Mode=OneWay}"
                                           Text="{x:Bind PeerCount, Mode=OneWay}" />
                                <TextBlock Grid.Column="6" VerticalAlignment="Center" HorizontalAlignment="Center"
                                           Foreground="{x:Bind RowForeground, Mode=OneWay}"
                                           Text="{x:Bind StateText, Mode=OneWay}" />
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </Grid>
</Window>
